#!/bin/sh -e
# Copyright (c) 2026 Contributors to the LotusInputMethod project
# SPDX-License-Identifier: GPL-3.0-or-later

svc="$(basename "$(pwd)")"
user="${svc#*.}"
if [ "$user" = "$svc" ]; then
    echo "fcitx5-lotus cannot be started directly." >&2
    echo "Use symlink like: fcitx5-lotus.<user>" >&2
    exit 1
fi

exec 2>&1
exec chpst -u uinput_proxy:input /usr/bin/fcitx5-lotus-server -u "$user"
